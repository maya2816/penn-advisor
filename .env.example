# Copy to .env.local (gitignored) for `vercel dev` — never commit real keys.
ANTHROPIC_API_KEY=

# Optional override (default is set in api/chat.js)
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# Penn Course Review API — OPTIONAL.
# The bulk of PCR data (catalog, search, attributes, basic ratings) is
# served unauthenticated, so the client works without a token. Only the
# DEEP review aggregate endpoints (`/api/review/course/{code}`, etc.)
# require Penn Labs SSO. Until we wire up real OAuth, you can paste a
# Bearer token from DevTools (login at penncoursereview.com → Network
# tab → copy the Authorization header value).
#
# PCR_TOKEN is read by api/chat.js (server-side, used by the chat
# advisor's lookup_course_reviews tool). VITE_PCR_TOKEN would be read
# by browser code, but no current client component needs it — leave it
# blank unless you intentionally call fetchReviews from the browser.
PCR_TOKEN=
# VITE_PCR_TOKEN=
